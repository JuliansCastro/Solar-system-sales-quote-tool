# Environment variables for Solar Quote App
# Copy this file as .env and fill in your values

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=solar_quote_db
DB_USER=solar_user
DB_PASSWORD=change-this-now
DB_HOST=localhost
DB_PORT=5432

# Backup policy
BACKUP_DIR=./backups
BACKUP_RETENTION_HOURS=168

# Backup scheduler configuration
BACKUP_HOURLY_ENABLED=true
BACKUP_INTERVAL_HOURS=1

# Daily backup at 6:00 PM (18:00) - detects date change automatically
BACKUP_DAILY_ENABLED=true
BACKUP_DAILY_HOUR=18
BACKUP_DAILY_MINUTE=0
BACKUP_DAILY_RETENTION_HOURS=336

# Monthly backup (1st of month at 3:30 AM)
BACKUP_MONTHLY_ENABLED=true
BACKUP_RETENTION_MONTHS=2592
BACKUP_MONTHLY_DAY=1
BACKUP_MONTHLY_HOUR=3
BACKUP_MONTHLY_MINUTE=30

# Monthly restore drill (disabled by default - enable for recovery testing)
BACKUP_MONTHLY_DRILL_ENABLED=false
BACKUP_DRILL_DAY=15
BACKUP_DRILL_HOUR=4
BACKUP_DRILL_MINUTE=0

# Company Info
COMPANY_NAME=Solar Energy Solutions
COMPANY_PHONE=+57 300 000 0000
COMPANY_EMAIL=info@solarenergy.com
COMPANY_ADDRESS=Bogotá, Colombia
COMPANY_NIT=000.000.000-0
